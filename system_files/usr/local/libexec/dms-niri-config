#!/usr/bin/env bash
set -euo pipefail

STAMP="$HOME/.local/state/dms-niri-config.done"

[[ -f "$STAMP" ]] && exit 0

mkdir -p "$(dirname "$STAMP")"

# ==============================================================================
# Replace existing Niri config with image defaults
# ==============================================================================

NIRI_DIR="$HOME/.config/niri"

if [[ -d "$NIRI_DIR" ]]; then
    mv "$NIRI_DIR" \
       "$HOME/.config/niri.pre-dms-niri-backup.$(date +%Y%m%d-%H%M%S)"
fi

mkdir -p "$HOME/.config"

cp -r /etc/skel/.config/niri \
      "$HOME/.config/"

touch "$STAMP"

